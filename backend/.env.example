# Copy to .env and adjust as needed for local dev.
APP_ENV=development
DATABASE_URL=postgresql+psycopg://musper:musper@localhost:5434/musper

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# JWT / auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_REFRESH_REMEMBER_TTL_DAYS=30
RESET_TOKEN_TTL_MINUTES=30
VERIFY_TOKEN_TTL_HOURS=24

# Cookies — set COOKIE_SECURE=true in production (requires HTTPS)
COOKIE_DOMAIN=
COOKIE_SECURE=false
